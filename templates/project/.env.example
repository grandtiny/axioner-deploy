# axioner-deploy 项目模板的 .env.example
#
# 部署时：
#   1. cp .env.example .env
#   2. 编辑 .env 填入真实值
#   3. AI（Claude/Codex/Gemini）永远不修改 .env
#
# 占位符约定：值含 `your_` / `_here` / `<...>` 会被 deploy.py 检测并暂停

PORT={{PORT}}
NODE_ENV=production

# 应用密钥（按需）
# SECRET_KEY=your_secret_here
# JWT_SECRET=your_jwt_secret_here
# DATABASE_URL=your_database_url_here
